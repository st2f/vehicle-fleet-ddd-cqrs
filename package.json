{
  "name": "vehicle-fleet-ddd-cqrs",
  "private": true,
  "version": "1.0.0",
  "description": "TypeScript fleet management exercise using DDD-style aggregates, command handlers, Cucumber scenarios and PostgreSQL persistence.",
  "main": "dist/index.js",
  "scripts": {
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "test": "cucumber-js",
    "test:critical": "cucumber-js --tags @critical",
    "test:postgres": "cucumber-js --profile postgres",
    "test:postgres:colima": "DOCKER_HOST=unix://$HOME/.colima/default/docker.sock TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE=/var/run/docker.sock cucumber-js --profile postgres",
    "test:postgres:colima:html": "mkdir -p reports && DOCKER_HOST=unix://$HOME/.colima/default/docker.sock TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE=/var/run/docker.sock cucumber-js --profile postgres --format html:reports/postgres-colima.html",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@cucumber/cucumber": "^12.9.0",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "testcontainers": "^12.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "pg": "^8.21.0"
  }
}
